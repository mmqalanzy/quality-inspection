    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "latest",
    "playwright": "latest",
    "prettier": "latest",
    "prisma": "^5.22.0",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.62.1",
